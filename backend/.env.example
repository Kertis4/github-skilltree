# GitHub SkillTree - backend environment
# Copy this file to "backend/.env" and fill in the values.
# backend/.env is git-ignored - NEVER commit real secrets.
#
# Create a GitHub OAuth app:
#   GitHub -> Settings -> Developer settings -> OAuth Apps -> New OAuth App
#   - Homepage URL:               http://localhost:5173
#   - Authorization callback URL: http://localhost:8000/auth/github/callback
# Then copy the Client ID and generate a Client secret below.

# OAuth app Client ID (not secret, but configured here for convenience).
GITHUB_CLIENT_ID=

# OAuth app Client SECRET - this is a credential. Keep it only in backend/.env.
GITHUB_CLIENT_SECRET=

# Must EXACTLY match the OAuth app's Authorization callback URL above.
GITHUB_REDIRECT_URI=http://localhost:8000/auth/github/callback

# The frontend origin allowed to receive results (postMessage + CORS).
FRONTEND_ORIGIN=http://localhost:5173

# Space-separated scopes. Minimal + public-only for the demo.
OAUTH_SCOPES=read:user public_repo

# --- GitHub service token (recruiter "analyze any user" mode) — OPTIONAL ---
# Enables the /analyze/github-user endpoint so recruiters can paste ANY public
# profile (no sign-in) and run the skill checks on it. Create a token at:
#   GitHub -> Settings -> Developer settings -> Personal access tokens
# It only reads PUBLIC data, so it needs no special scopes (a classic token with
# `public_repo`, a fine-grained token with public read-only, or even a no-scope
# token all work — GitHub's GraphQL API just requires *some* valid token). This
# is a credential: keep it only in backend/.env. Leave blank to disable the flow.
GITHUB_SERVICE_TOKEN=

# --- Azure OpenAI (analysis pipeline / map-stage LLM) ---
# Use the resource's *Azure OpenAI* endpoint (NOT the Foundry Project endpoint).
AZURE_OPENAI_ENDPOINT=

# API key for the resource. This is a credential - keep it only in backend/.env.
AZURE_OPENAI_API_KEY=

# The deployment name to call (the model= argument), e.g. gpt-4.1-mini.
AZURE_OPENAI_DEPLOYMENT=gpt-4.1-mini

# Data-plane API version (supports structured json_schema outputs).
AZURE_OPENAI_API_VERSION=2024-10-21

# --- Azure OpenAI (recommendation-stage LLM) — OPTIONAL ---
# Powers the natural-language explanation in the "learn next" recommendations
# panel. Unlike the map-stage endpoint above, this must be the FULL chat-
# completions URL (including the deployment + api-version query string), because
# the recommendation engine POSTs to it directly. Leave blank to skip the prose
# explanation — deterministic recommendations are still produced without it.
AZURE_OPENAI_RECOMMENDATION_ENDPOINT=

# API key for the recommendation resource. A credential — keep it only in backend/.env.
AZURE_OPENAI_RECOMMENDATION_API_KEY=

# The recommendation deployment / model name (the model= argument).
AZURE_OPENAI_RECOMMENDATION_DEPLOYMENT=gpt-5-mini
