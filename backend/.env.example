# GitHub SkillTree - backend environment
# Copy this file to "backend/.env" and fill in the values.
# backend/.env is git-ignored - NEVER commit real secrets.
#
# Create a GitHub OAuth app:
#   GitHub -> Settings -> Developer settings -> OAuth Apps -> New OAuth App
#   - Homepage URL:               http://localhost:5173
#   - Authorization callback URL: http://localhost:8000/auth/github/callback
# Then copy the Client ID and generate a Client secret below.

# OAuth app Client ID (not secret, but configured here for convenience).
GITHUB_CLIENT_ID=

# OAuth app Client SECRET - this is a credential. Keep it only in backend/.env.
GITHUB_CLIENT_SECRET=

# Must EXACTLY match the OAuth app's Authorization callback URL above.
GITHUB_REDIRECT_URI=http://localhost:8000/auth/github/callback

# The frontend origin allowed to receive results (postMessage + CORS).
FRONTEND_ORIGIN=http://localhost:5173

# Space-separated scopes. Minimal + public-only for the demo.
OAUTH_SCOPES=read:user public_repo
