# GitHub SkillTree — frontend environment
# Copy to ".env.local" and fill in to enable real GitHub OAuth.
# Without these, the login button runs in a safe "preview" mode.

# OAuth App client id (Settings -> Developer settings -> OAuth Apps)
VITE_GITHUB_CLIENT_ID=

# Backend API base URL (see API contract in the project README).
# Defaults to the current origin when empty.
VITE_API_BASE_URL=
