# GitHub SkillTree — frontend environment
# Only needed if your backend runs somewhere other than the default.
# Copy to ".env.local" to override.
#
# The GitHub OAuth client id AND secret live on the BACKEND (backend/.env),
# never here — the browser never sees a credential.

# Base URL of the FastAPI backend. Defaults to http://localhost:8000 when empty.
VITE_API_BASE_URL=http://localhost:8000
